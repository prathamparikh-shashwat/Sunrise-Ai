# Per-business Google Spreadsheet IDs
# Each business type writes to its own dedicated spreadsheet.
TAILORING_SPREADSHEET_ID=15rfnQg8XN1t-PA8Bhh4A-ohVDgqmOHFhZPUxxk9XuO8
GENERAL_SPREADSHEET_ID=1-06egJwvlOA9uq96buLZVyIultTbaOrvIKMSIqcC1g0
RETAIL_SPREADSHEET_ID=1edQAFpksTNVMvfu8pyyEqA1uII2xI8OG8k8Sp0DQiWc

# Optional legacy fallback if per-business IDs are not set
SPREADSHEET_ID=

# Path to the Google Cloud Service Account JSON file (optional if using local ADC via gcloud or individual env variables)
# GOOGLE_APPLICATION_CREDENTIALS=

# Google Service Account Credentials (preferred, avoids local JSON files)
GOOGLE_TYPE=service_account
GOOGLE_PROJECT_ID=
GOOGLE_PRIVATE_KEY_ID=
GOOGLE_PRIVATE_KEY=
GOOGLE_CLIENT_EMAIL=
GOOGLE_CLIENT_ID=
GOOGLE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
GOOGLE_TOKEN_URI=https://oauth2.googleapis.com/token
GOOGLE_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
GOOGLE_CLIENT_X509_CERT_URL=
GOOGLE_UNIVERSE_DOMAIN=googleapis.com
GemAI_API_Key=
Router_Api_key=

# PostgreSQL Database Connection URL (e.g. postgresql://user:pass@host:port/dbname)
DB_URL=

# CORS Config (comma-separated list of origins, e.g. https://myfrontend.com, or * for all)
ALLOWED_ORIGINS=*

# Backend server configuration
PORT=8000
HOST=0.0.0.0

